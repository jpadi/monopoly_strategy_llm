# =============================================================================
# Monopoly Trade Evaluation System — root .gitignore
#
# Ignores machine-specific, generated, and regenerable artifacts only.
# Does NOT ignore source code, docs, schemas, specifications, or test fixtures.
# =============================================================================

# =============================================================================
# Python — bytecode and caches
# =============================================================================
__pycache__/
*.py[cod]
*$py.class

# =============================================================================
# Virtual environments
# =============================================================================
.venv/
venv/
env/
ENV/
.python-version
pip-wheel-metadata/

# =============================================================================
# Python — build and packaging
# =============================================================================
build/
dist/
.eggs/
*.egg
*.egg-info/
wheels/

# =============================================================================
# Coverage
# =============================================================================
.coverage
.coverage.*
coverage.xml
coverage.json
htmlcov/
coverage/

# =============================================================================
# Test runners and caches
# =============================================================================
.pytest_cache/
.cache/
.hypothesis/

# =============================================================================
# Type checkers and linters
# =============================================================================
.dmypy.json
.mypy_cache/
.pyre/
.pytype/
.ruff_cache/

# =============================================================================
# Python tooling
# =============================================================================
.ipynb_checkpoints/
.nox/
.pybuilder/
.tox/

# =============================================================================
# IDEs — IntelliJ IDEA / JetBrains
# =============================================================================
.idea/
*.iml
out/

# =============================================================================
# Editors — VS Code
# =============================================================================
.vscode/

# =============================================================================
# Editors — Cursor
# =============================================================================
.cursor/
.cursor-cache/
.cursor-tmp/
.cursorindex/

# =============================================================================
# Logs
# =============================================================================
*.log
log/
logs/

# =============================================================================
# Temporary files
# =============================================================================
*.bak
*.orig
*.rej
*.swo
*.swp
*.temp
*.tmp
*~

# =============================================================================
# OS files
# =============================================================================
# macOS
.AppleDouble
.DS_Store
.LSOverride

# Windows
Desktop.ini
Thumbs.db

# =============================================================================
# Local environment configuration
# =============================================================================
.env
.env.*
!.env.example
.local/

# =============================================================================
# Generated documentation
# =============================================================================
docs/_build/
mkdocs/site/
site/

# =============================================================================
# Generated reports and benchmarks
# =============================================================================
benchmark-results/
performance/
profiling/
reports/
test-reports/

# =============================================================================
# External dependencies (generated / vendored locally)
# =============================================================================
.external/
.external_dependencies/
third_party/
vendor/

# =============================================================================
# Package managers (harmless if unused)
# =============================================================================
node_modules/
npm-debug.log*
pnpm-debug.log*
yarn-error.log*

# =============================================================================
# Generated archives
# =============================================================================
*.7z
*.gz
*.rar
*.tar
*.zip

# =============================================================================
# Local databases
# =============================================================================
*.db
*.sqlite
*.sqlite3

# =============================================================================
# Local runtime files
# =============================================================================
*.pid
*.seed
*.lock
!poetry.lock
!requirements.lock
!uv.lock
