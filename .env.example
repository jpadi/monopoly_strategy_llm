# Cursor LLM Judge integration (inline spec delivery via combined prompt — see docs/llm_platform/cursor/)
#
# Copy this file to .env at the repository root and set your key.
# The reference implementation and pytest load .env automatically.
# Existing process environment variables take precedence over .env values.

# Production + integration tests — read by EnvironmentLoader and CursorLlmClient bootstrap.
CURSOR_API_KEY=

# Pytest only — set to 1 to skip clearing artifact/ at pytest session start.
MONOPOLY_KEEP_ARTIFACTS=

# Integration tests only — default model for live Cursor scenarios (test/python/integration/LlmEvaluation/conftest.py).
# Production model selection uses llm_execution.model in the Judge request payload, not this variable.
CURSOR_JUDGE_MODEL=composer-2.5

# Reserved for a future SemanticResponseAssessor integration path (not wired in 1.2.0)
# CURSOR_ASSESSOR_MODEL=

# Reserved for future env-driven LlmExecutionConfig timeout wiring (not wired in 1.2.0)
# LLM_REQUEST_TIMEOUT_SECONDS=120
